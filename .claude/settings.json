{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(chmod *)",
      "Bash(curl *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(gh api *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git switch *)",
      "Bash(bun *)",
      "Bash(jq *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(moon *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip3 *)",
      "Bash(pkill *)",
      "Bash(python3 *)",
      "Bash(rm -rf retro-dashboard/*)",
      "Edit(*.md)",
      "Edit(*.mbt)",
      "Edit(*.json)",
      "Edit(*.ts)",
      "Edit(*.css)",
      "Edit(*.html)",
      "Edit(*.js)",
      "Edit(*.yaml)",
      "Edit(*.yml)",
      "Edit(*.sh)",
      "Edit(*.py)",
      "Edit(*.txt)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(gh issue create *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-md.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-md.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notification.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pdd@kzmshx": true
  },
  "language": "ja"
}
