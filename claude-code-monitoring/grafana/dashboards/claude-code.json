{
  "uid": "claude-code-overview",
  "title": "Claude Code Overview",
  "tags": ["claude-code"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (session_id) (claude_code_cost_usage_USD_total))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Lines of Code",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "API Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name = `api_request` [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "super-light-blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "title": "Tool Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name = `tool_result` [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "light-green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 10,
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "id": 11,
      "title": "Token Usage by Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "id": 12,
      "title": "Cost by Session",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (session_id, model) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "session_id": "Session",
              "model": "Model",
              "Value": "Cost (USD)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [{ "field": "Cost (USD)", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cost (USD)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Session" },
            "properties": [
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    },
    {
      "id": 20,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model) (increase(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 21,
      "title": "Tokens Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (increase(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      }
    },
    {
      "id": 30,
      "title": "Tool Usage (Loki)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name = `tool_result` [$__interval]))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "xTickLabelRotation": -45
      }
    },
    {
      "id": 31,
      "title": "Tool Decisions",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "sum by (tool_name, decision) (count_over_time({service_name=\"claude-code\"} | event_name = `tool_decision` [$__interval]))",
          "legendFormat": "{{tool_name}} ({{decision}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "xTickLabelRotation": -45
      }
    },
    {
      "id": 40,
      "title": "API Request Duration (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "avg_over_time({service_name=\"claude-code\"} | event_name = `api_request` | json | unwrap duration_ms [$__interval]) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 41,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "uid": "PBFA97CFB590B2093", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / (sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) + sum(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m])) + sum(increase(claude_code_token_usage_tokens_total{type=\"cacheCreation\"}[5m])))",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 50,
      "title": "Recent Events",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "uid": "P8E80F9AEF21F6940", "type": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
